# Matrix 全栈配置 - 环境变量 (Conduwuit + Bridges)
# ==================================================

# 域名设置 (本地开发用 localhost)
MATRIX_DOMAIN=localhost
MATRIX_SERVER_NAME=localhost

# 端口配置
CONDUWUIT_PORT=6167
ELEMENT_PORT=8080
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Conduwuit 配置
CONDUWUIT_REGISTRATION_TOKEN=matrix_dev_registration_token_2026

# Bridge 端口配置 (Appservice HTTP 端口)
TELEGRAM_APPSERVICE_PORT=29317
DISCORD_APPSERVICE_PORT=29318
WHATSAPP_APPSERVICE_PORT=29319
SLACK_APPSERVICE_PORT=29320
SIGNAL_APPSERVICE_PORT=29321
GMESSAGES_APPSERVICE_PORT=29322

# Bridge Telegram 额外配置 (需要从 https://my.telegram.org 获取)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Bridge Discord 额外配置 (需要从 Discord Developer Portal 获取)
DISCORD_BOT_TOKEN=your_discord_bot_token

# 项目根目录 (自动检测)
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
